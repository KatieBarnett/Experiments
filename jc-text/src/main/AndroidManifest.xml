<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Experiments">

        <!--            android:configChanges="locale|layoutDirection|uiMode"-->
        <activity
            android:name="dev.katiebarnett.experiments.jctext.MainActivity"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|locale|layoutDirection|uiMode"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.Experiments">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>